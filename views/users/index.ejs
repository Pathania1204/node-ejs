<h1>User Admin Interface</h1>
<p><a href="/users/add">Add User</a></p>
<ol>
<% users.forEach(user => { %>
<li>
  <%= user.name  %> -
  <%= user.email  %> -
  <%= user.role  %>
  <a href="/users/<%= user._id %>/edit">Edit</a>
  <a href="/users/<%= user._id %>/delete">Delete</a>
  </a>
</li>
<% }) %>
</ol>